generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  city             String
  state            String
  type             CollegeType
  streams          String[]
  nirfRank         Int?
  established      Int
  website          String?
  accreditation    String?
  createdAt        DateTime          @default(now())
  admissionCutoffs AdmissionCutoff[]
  courseFees       CourseFee[]
  placementStats   PlacementStat[]
  reviews          Review[]
  shortlists       Shortlist[]
}

model CourseFee {
  id        String  @id @default(cuid())
  collegeId String
  course    String
  degree    String
  annualFee Int
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model PlacementStat {
  id            String   @id @default(cuid())
  collegeId     String
  year          Int
  avgPackage    Float
  maxPackage    Float
  placementPct  Float
  topRecruiters String[]
  college       College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([collegeId, year])
  @@index([collegeId])
}

model AdmissionCutoff {
  id          String  @id @default(cuid())
  collegeId   String
  exam        String
  year        Int
  category    String
  branch      String  @default("All Branches")
  cutoffValue Float
  college     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([collegeId, exam, year, category, branch])
  @@index([collegeId])
}

model Review {
  id              String       @id @default(cuid())
  collegeId       String
  authorName      String
  batchYear       Int
  stream          String
  ratingOverall   Float
  ratingPlacement Float
  ratingFaculty   Float
  ratingInfra     Float
  body            String
  status          ReviewStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  college         College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId, status])
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  passwordHash String
  createdAt    DateTime    @default(now())
  shortlists   Shortlist[]
}

model Shortlist {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  createdAt DateTime @default(now())
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
  @@index([userId])
}

enum CollegeType {
  GOVT
  PRIVATE
  DEEMED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
